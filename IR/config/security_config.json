{
    "security": {
        "api_token_required": true,
        "api_token": "CHANGE_THIS_SECRET_TOKEN_IN_PRODUCTION",
        "tls_enabled": true,
        "tls_cert_path": "/etc/ssl/certs/irremote.crt",
        "tls_key_path": "/etc/ssl/private/irremote.key",
        "tls_ca_path": "/etc/ssl/certs/ca.crt",
        "rate_limit_enabled": true,
        "rate_limit_requests": 100,
        "rate_limit_window_seconds": 60,
        "input_validation_enabled": true,
        "security_logging_enabled": true,
        "allowed_origins": [
            "http://localhost:3000",
            "http://localhost:8080"
        ],
        "password_policy": {
            "min_length": 8,
            "require_uppercase": true,
            "require_lowercase": true,
            "require_numbers": true,
            "require_special_chars": true
        },
        "session_security": {
            "session_timeout_minutes": 30,
            "max_concurrent_sessions": 5,
            "secure_cookies": true
        },
        "encryption": {
            "algorithm": "AES-256-GCM",
            "key_rotation_days": 90
        }
    },
    "mqtt_security": {
        "use_tls": true,
        "username_required": true,
        "password_required": true,
        "client_cert_required": false,
        "ca_cert_path": "/etc/ssl/certs/mqtt_ca.crt",
        "client_cert_path": "/etc/ssl/certs/mqtt_client.crt",
        "client_key_path": "/etc/ssl/private/mqtt_client.key"
    },
    "serial_security": {
        "authentication_required": true,
        "max_message_size_bytes": 1024,
        "rate_limit_messages_per_second": 10,
        "allowed_commands": [
            "ping",
            "status",
            "ir_send",
            "ir_receive",
            "config_get",
            "config_set",
            "device_list",
            "device_control",
            "system_info"
        ]
    },
    "logging": {
        "security_events": true,
        "failed_attempts": true,
        "access_logs": true,
        "log_retention_days": 30,
        "log_file_path": "/var/log/irremote/security.log"
    }
}
